            "exec": [
              "// Verificar éxito\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Verificar que recibimos una lista\r",
              "pm.test(\"Devuelve una lista de personajes\", function () {\r",
