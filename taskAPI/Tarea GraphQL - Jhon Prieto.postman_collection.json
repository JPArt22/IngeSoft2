      "name": "1. Query Simple - Continentes",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });\r",
              "pm.test(\"Devuelve continentes\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data.continents).to.be.an('array');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\r\n  continents {\r\n    code\r\n    name\r\n  }\r\n}",
            "variables": ""
          }
        },
        "url": {
          "raw": "https://countries.trevorblades.com/graphql",
